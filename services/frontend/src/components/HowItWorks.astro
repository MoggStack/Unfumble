---
// HowItWorks.astro — 3-step animated process
---

<section id="how-it-works" class="relative py-32 px-6 overflow-hidden">

  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 40% at 50% 50%, rgba(20,184,166,0.04) 0%, transparent 70%);"></div>

  <div class="max-w-6xl mx-auto">

    <!-- Section header -->
    <div class="text-center mb-20 reveal">
      <span class="inline-block px-4 py-1 rounded-full text-sm font-semibold text-teal-400 bg-teal-400/10 border border-teal-400/20 mb-4 tracking-wider uppercase">
        How It Works
      </span>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-white mb-4">
        Three steps to a
        <span class="gradient-text"> perfect photo</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-xl mx-auto">
        No Photoshop. No expensive photographers. No waiting days for results.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative">

      <!-- Connector line (desktop) -->
      <div class="hidden md:block absolute top-20 left-0 right-0 h-px"
           style="background: linear-gradient(90deg, transparent 10%, rgba(20,184,166,0.3) 30%, rgba(129,140,248,0.3) 60%, transparent 90%); margin: 0 12%;"></div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">

        <!-- Step 1 -->
        <div class="reveal reveal-delay-1 group flex flex-col items-center text-center">
          <div class="relative mb-8">
            <!-- Outer glow ring -->
            <div class="absolute inset-0 rounded-full bg-teal-500/20 blur-xl scale-110 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <!-- Icon circle -->
            <div class="relative w-20 h-20 rounded-full flex items-center justify-center border border-teal-500/40 glass-card group-hover:border-teal-400/80 transition-all duration-300 group-hover:scale-110">
              <svg class="w-9 h-9 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
              </svg>
              <!-- Step number badge -->
              <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-teal-500 text-white text-xs font-bold flex items-center justify-center">1</span>
            </div>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Upload your photo</h3>
          <p class="text-slate-400 text-sm leading-relaxed max-w-xs">
            Drag and drop or browse your device. We accept JPG, PNG, HEIC — any format, any resolution.
          </p>
          <!-- mini decorative tags -->
          <div class="flex flex-wrap gap-2 mt-4 justify-center">
            <span class="px-2 py-0.5 rounded text-xs bg-surface-700 text-slate-400 border border-slate-700">JPG</span>
            <span class="px-2 py-0.5 rounded text-xs bg-surface-700 text-slate-400 border border-slate-700">PNG</span>
            <span class="px-2 py-0.5 rounded text-xs bg-surface-700 text-slate-400 border border-slate-700">HEIC</span>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="reveal reveal-delay-2 group flex flex-col items-center text-center">
          <div class="relative mb-8">
            <div class="absolute inset-0 rounded-full bg-violet-500/20 blur-xl scale-110 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="relative w-20 h-20 rounded-full flex items-center justify-center border border-violet-500/40 glass-card group-hover:border-violet-400/80 transition-all duration-300 group-hover:scale-110">
              <svg class="w-9 h-9 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
              </svg>
              <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-violet-500 text-white text-xs font-bold flex items-center justify-center">2</span>
            </div>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Pick a use-case</h3>
          <p class="text-slate-400 text-sm leading-relaxed max-w-xs">
            Choose from LinkedIn, passport, Instagram, job applications, and more. We tailor everything to that specific context.
          </p>
          <div class="flex flex-wrap gap-2 mt-4 justify-center">
            <span class="px-2 py-0.5 rounded text-xs bg-surface-700 text-slate-400 border border-slate-700">LinkedIn</span>
            <span class="px-2 py-0.5 rounded text-xs bg-surface-700 text-slate-400 border border-slate-700">Passport</span>
            <span class="px-2 py-0.5 rounded text-xs bg-surface-700 text-slate-400 border border-slate-700">+more</span>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="reveal reveal-delay-3 group flex flex-col items-center text-center">
          <div class="relative mb-8">
            <div class="absolute inset-0 rounded-full bg-pink-500/20 blur-xl scale-110 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="relative w-20 h-20 rounded-full flex items-center justify-center border border-pink-500/40 glass-card group-hover:border-pink-400/80 transition-all duration-300 group-hover:scale-110">
              <svg class="w-9 h-9 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-pink-500 text-white text-xs font-bold flex items-center justify-center">3</span>
            </div>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Download your result</h3>
          <p class="text-slate-400 text-sm leading-relaxed max-w-xs">
            Get your AI-polished photo instantly in HD, ready for upload. Share, print, or use directly — no extra steps.
          </p>
          <div class="flex flex-wrap gap-2 mt-4 justify-center">
            <span class="px-2 py-0.5 rounded text-xs bg-surface-700 text-slate-400 border border-slate-700">HD Quality</span>
            <span class="px-2 py-0.5 rounded text-xs bg-surface-700 text-slate-400 border border-slate-700">Instant</span>
          </div>
        </div>

      </div>
    </div>

    <!-- Bottom CTA nudge -->
    <div class="text-center mt-16 reveal">
      <a
        href="/app"
        class="group inline-flex items-center gap-2 text-teal-400 hover:text-teal-300 font-semibold transition-colors duration-200"
      >
        Start with your first photo
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
