---
// HowItWorks.astro — B&W editorial, numbered steps
---

<section id="how-it-works" style="background:#080808;padding:8rem 1.5rem;position:relative;overflow:hidden;">

  <!-- Faint horizontal rule at top -->
  <div style="position:absolute;top:0;left:0;right:0;height:1px;background:rgba(255,255,255,0.05);"></div>

  <div style="max-width:72rem;margin:0 auto;">

    <!-- Header row -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:2rem;margin-bottom:5rem;flex-wrap:wrap;" class="reveal">
      <div>
        <p style="font-family:'Space Mono',monospace;font-size:0.65rem;letter-spacing:0.18em;text-transform:uppercase;color:#5a5a5a;margin-bottom:1.25rem;">
          How It Works — Three Steps
        </p>
        <h2 class="split-text" style="font-family:'Playfair Display',Georgia,serif;font-size:clamp(2.2rem,5vw,4rem);font-weight:900;line-height:1.0;letter-spacing:-0.03em;color:#fafafa;max-width:600px;">
          From fumbled to flawless.
        </h2>
      </div>
      <p style="font-family:'DM Sans',system-ui,sans-serif;font-size:1rem;font-weight:300;color:#5a5a5a;max-width:300px;line-height:1.7;margin-bottom:0.25rem;">
        No Photoshop. No photographer.<br/>No waiting days for results.
      </p>
    </div>

    <!-- Steps -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:0;border-top:1px solid rgba(255,255,255,0.06);">

      <!-- Step 1 -->
      <div class="reveal d1 step-col" style="padding:2.5rem 2rem 2.5rem 0;border-right:1px solid rgba(255,255,255,0.06);">
        <div style="display:flex;align-items:baseline;gap:1rem;margin-bottom:1.75rem;">
          <span style="font-family:'Playfair Display',Georgia,serif;font-size:4rem;font-weight:900;color:rgba(255,255,255,0.06);line-height:1;letter-spacing:-0.04em;">01</span>
          <div style="width:32px;height:32px;border:1px solid rgba(255,255,255,0.12);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#fafafa" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/>
            </svg>
          </div>
        </div>
        <h3 style="font-family:'DM Sans',system-ui,sans-serif;font-size:1.1rem;font-weight:600;color:#fafafa;margin-bottom:0.75rem;letter-spacing:-0.01em;">Upload your photos</h3>
        <p style="font-family:'DM Sans',system-ui,sans-serif;font-size:0.875rem;font-weight:300;color:#5a5a5a;line-height:1.75;margin-bottom:1.5rem;">Drag in whatever you've got — side angles, awkward selfies, low-light shots. Any format, any quality. The uglier, the better.</p>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
          {['JPG','PNG','HEIC','WEBP'].map(t => (
            <span style="font-family:'Space Mono',monospace;font-size:0.58rem;letter-spacing:0.08em;padding:3px 7px;border:1px solid rgba(255,255,255,0.08);color:#5a5a5a;border-radius:1px;">{t}</span>
          ))}
        </div>
      </div>

      <!-- Step 2 -->
      <div class="reveal d2 step-col" style="padding:2.5rem 2rem;border-right:1px solid rgba(255,255,255,0.06);">
        <div style="display:flex;align-items:baseline;gap:1rem;margin-bottom:1.75rem;">
          <span style="font-family:'Playfair Display',Georgia,serif;font-size:4rem;font-weight:900;color:rgba(255,255,255,0.06);line-height:1;letter-spacing:-0.04em;">02</span>
          <div style="width:32px;height:32px;border:1px solid rgba(255,255,255,0.12);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#fafafa" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
            </svg>
          </div>
        </div>
        <h3 style="font-family:'DM Sans',system-ui,sans-serif;font-size:1.1rem;font-weight:600;color:#fafafa;margin-bottom:0.75rem;letter-spacing:-0.01em;">Pick a use-case</h3>
        <p style="font-family:'DM Sans',system-ui,sans-serif;font-size:0.875rem;font-weight:300;color:#5a5a5a;line-height:1.75;margin-bottom:1.5rem;">Choose LinkedIn, passport, Instagram, or job application. We tailor every pixel to the specific context.</p>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
          {['LinkedIn','Passport','Instagram','Job App'].map(t => (
            <span style="font-family:'Space Mono',monospace;font-size:0.58rem;letter-spacing:0.08em;padding:3px 7px;border:1px solid rgba(255,255,255,0.08);color:#5a5a5a;border-radius:1px;">{t}</span>
          ))}
        </div>
      </div>

      <!-- Step 3 -->
      <div class="reveal d3 step-col" style="padding:2.5rem 0 2.5rem 2rem;">
        <div style="display:flex;align-items:baseline;gap:1rem;margin-bottom:1.75rem;">
          <span style="font-family:'Playfair Display',Georgia,serif;font-size:4rem;font-weight:900;color:rgba(255,255,255,0.06);line-height:1;letter-spacing:-0.04em;">03</span>
          <div style="width:32px;height:32px;border:1px solid rgba(255,255,255,0.12);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#fafafa" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
            </svg>
          </div>
        </div>
        <h3 style="font-family:'DM Sans',system-ui,sans-serif;font-size:1.1rem;font-weight:600;color:#fafafa;margin-bottom:0.75rem;letter-spacing:-0.01em;">Download your result</h3>
        <p style="font-family:'DM Sans',system-ui,sans-serif;font-size:0.875rem;font-weight:300;color:#5a5a5a;line-height:1.75;margin-bottom:1.5rem;">Get your HD photo instantly. Print-ready, share-ready, done. No subscriptions. No waiting.</p>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
          {['HD Quality','Instant','Print-ready'].map(t => (
            <span style="font-family:'Space Mono',monospace;font-size:0.58rem;letter-spacing:0.08em;padding:3px 7px;border:1px solid rgba(255,255,255,0.08);color:#5a5a5a;border-radius:1px;">{t}</span>
          ))}
        </div>
      </div>

    </div>

    <!-- Bottom rule + CTA -->
    <div style="border-top:1px solid rgba(255,255,255,0.06);margin-top:0;padding-top:2.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;" class="reveal">
      <p style="font-family:'Space Mono',monospace;font-size:0.62rem;letter-spacing:0.12em;text-transform:uppercase;color:#2a2a2a;">Ugly pics in. One perfect profile out.</p>
      <a href="/app" style="font-family:'DM Sans',system-ui,sans-serif;font-size:0.875rem;font-weight:600;text-decoration:none;color:#080808;background:#fafafa;padding:0.7rem 1.5rem;border:1px solid #fafafa;border-radius:1px;letter-spacing:0.02em;transition:all 0.2s;" onmouseover="this.style.background='#080808';this.style.color='#fafafa';this.style.boxShadow='0 0 0 1px #fafafa'" onmouseout="this.style.background='#fafafa';this.style.color='#080808';this.style.boxShadow='none'">
        Unfumble my photos →
      </a>
    </div>

  </div>
</section>

<style>
  @media (max-width: 768px) {
    .step-col { padding: 2rem 0 !important; border-right: none !important; border-bottom: 1px solid rgba(255,255,255,0.06); }
  }
</style>
