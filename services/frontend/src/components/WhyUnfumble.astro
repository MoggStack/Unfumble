---
// WhyUnfumble.astro — B&W Editorial why section
---

<section id="why-us" style="background:#080808;padding:8rem 1.5rem;position:relative;border-top:1px solid rgba(255,255,255,0.06);">
  <div style="max-width:72rem;margin:0 auto;">

    <!-- Header -->
    <div class="reveal" style="display:flex;align-items:flex-end;justify-content:space-between;gap:2rem;margin-bottom:5rem;flex-wrap:wrap;">
      <div>
        <p style="font-family:'Space Mono',monospace;font-size:0.65rem;letter-spacing:0.18em;text-transform:uppercase;color:#5a5a5a;margin-bottom:1.25rem;">
          Why UnFumble
        </p>
        <h2 class="reveal-up" style="font-family:'Playfair Display',Georgia,serif;font-size:clamp(2.2rem,5vw,4rem);font-weight:900;line-height:1.0;letter-spacing:-0.03em;color:#fafafa;max-width:400px;">
          Professional results. <br/><em style="font-family:'DM Sans',system-ui,sans-serif;font-weight:400;font-style:normal;letter-spacing:-0.05em;color:#888;">Zero effort.</em>
        </h2>
      </div>
      <p style="font-family:'DM Sans',system-ui,sans-serif;font-size:1rem;font-weight:300;color:#5a5a5a;max-width:320px;line-height:1.7;margin-bottom:0.25rem;">
        We built this because booking a photographer is expensive and photo editors require skills most people don't have.
      </p>
    </div>

    <!-- 2-column layout -->
    <div style="display:grid;grid-template-columns:1fr;gap:0;border:1px solid rgba(255,255,255,0.06);" class="why-grid">

      <!-- Left: feature list -->
      <div style="display:flex;flex-direction:column;border-right:1px solid rgba(255,255,255,0.06);" class="why-left">
        {[
          {
            title: 'Studio edits, not filters',
            body: 'We work from every angle you upload — reconstructing backgrounds, fixing lighting, correcting exposure, and reframing the way a professional photographer would. Not a cheap filter.',
          },
          {
            title: 'No design skills needed',
            body: 'Zero Photoshop. Zero studio. Zero lighting knowledge. Pick your context, upload your photo, done. We handle every pixel of the technical magic.',
          },
          {
            title: 'Results in seconds',
            body: 'Not hours. Not days. Our pipeline delivers your polished photo faster than you can book a photographer or open an editing tool.',
          }
        ].map((f, i) => (
          <div
            class={`reveal d${i + 1}`}
            style={`padding:2.5rem;display:flex;gap:1.5rem;align-items:flex-start;border-bottom:${i < 2 ? '1px solid rgba(255,255,255,0.06)' : 'none'};transition:background 0.3s;`}
            onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background='transparent'"
          >
            <div style="font-family:'Playfair Display',Georgia,serif;font-size:2rem;font-weight:900;color:rgba(255,255,255,0.15);line-height:1;margin-top:-4px;">
              0{i+1}
            </div>
            <div>
              <h3 style="font-family:'DM Sans',system-ui,sans-serif;font-size:1.1rem;font-weight:600;color:#fafafa;margin-bottom:0.5rem;letter-spacing:-0.01em;">{f.title}</h3>
              <p style="font-family:'DM Sans',system-ui,sans-serif;font-size:0.875rem;font-weight:300;color:#5a5a5a;line-height:1.75;">{f.body}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Right: stats panel -->
      <div class="reveal d2 why-right" style="padding:4rem 3rem;display:flex;flex-direction:column;justify-content:center;">
        
        <div style="display:flex;flex-direction:column;gap:3rem;margin-bottom:4rem;">
          {[
            { val: '~5s', label: 'Processing time', sub: 'from upload to download' },
            { val: '4+',  label: 'Presets ready',   sub: 'growing library' },
            { val: 'HD',  label: 'Output quality',  sub: 'print-ready resolution' }
          ].map((s) => (
            <div>
              <div style="font-family:'Space Mono',monospace;font-size:3.5rem;font-weight:300;line-height:1;color:#fafafa;margin-bottom:0.5rem;letter-spacing:-0.05em;">{s.val}</div>
              <div style="font-family:'DM Sans',system-ui,sans-serif;font-weight:600;font-size:0.9rem;color:#fafafa;margin-bottom:0.25rem;">{s.label}</div>
              <div style="font-family:'Space Mono',monospace;font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:#5a5a5a;">{s.sub}</div>
            </div>
          ))}
        </div>

        <a href="/app" style="display:inline-block;text-align:center;font-family:'DM Sans',system-ui,sans-serif;font-size:0.9rem;font-weight:600;color:#080808;background:#fafafa;padding:1rem 2rem;text-decoration:none;transition:background 0.2s,color 0.2s;" onmouseover="this.style.background='#080808';this.style.color='#fafafa';this.style.boxShadow='0 0 0 1px #fafafa'" onmouseout="this.style.background='#fafafa';this.style.color='#080808';this.style.boxShadow='none'">
          Unfumble my photos →
        </a>

      </div>

    </div>
  </div>
</section>

<style>
  @media (min-width: 900px) {
    .why-grid { grid-template-columns: 1.2fr 1fr !important; }
  }
  @media (max-width: 899px) {
    .why-left { border-right: none !important; border-bottom: 1px solid rgba(255,255,255,0.06) !important; }
    .why-right { padding: 3rem 2rem !important; }
  }
</style>
