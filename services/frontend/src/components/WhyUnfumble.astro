---
// WhyUnfumble.astro — benefits / value props section

const features = [
  {
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z" /></svg>`,
    title: 'AI-powered edits, not filters',
    body: 'We don\'t slap a filter on your selfie. Our models intelligently reconstruct backgrounds, fix lighting, correct exposure, and reframe — the way a professional photographer would.',
    accent: '#14b8a6',
  },
  {
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
    title: 'No design skills needed',
    body: 'Zero knowledge of Photoshop, lighting, or studio setups required. Pick your context, upload your photo, done. We handle every pixel of the technical work.',
    accent: '#818cf8',
  },
  {
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
    title: 'Fast turnaround',
    body: 'Results in seconds — not hours, not days. Our GPU-accelerated pipeline delivers your final photo faster than you can open Canva or book a studio session.',
    accent: '#fb923c',
  },
];
---

<section id="why-unfumble" class="relative py-32 px-6 overflow-hidden">

  <!-- Decorative gradient blob -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-teal-500/4 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-6xl mx-auto">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Text content -->
      <div>
        <div class="reveal">
          <span class="inline-block px-4 py-1 rounded-full text-sm font-semibold text-teal-400 bg-teal-400/10 border border-teal-400/20 mb-6 tracking-wider uppercase">
            Why UnFumble
          </span>
          <h2 class="text-4xl sm:text-5xl font-extrabold text-white mb-6 leading-tight">
            Professional results,
            <br />
            <span class="gradient-text">zero effort</span>
          </h2>
          <p class="text-slate-400 text-lg leading-relaxed mb-8">
            We built UnFumble because booking a photographer is expensive, and editing apps require skills most people don't have. There had to be a better way.
          </p>
        </div>

        <!-- Feature list -->
        <div class="space-y-6">
          {features.map((f, i) => (
            <div class={`reveal reveal-delay-${i + 1} group flex gap-4 items-start p-4 rounded-xl border border-transparent hover:border-white/5 hover:bg-white/2 transition-all duration-300`}>
              <div
                class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center transition-transform duration-300 group-hover:scale-110"
                style={`color: ${f.accent}; background: ${f.accent}20;`}
              >
                <div class="w-5 h-5" set:html={f.icon} />
              </div>
              <div>
                <h3 class="text-base font-semibold text-white mb-1">{f.title}</h3>
                <p class="text-slate-400 text-sm leading-relaxed">{f.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Stats / visual panel -->
      <div class="reveal reveal-delay-2">
        <div class="relative">

          <!-- Main card -->
          <div class="glass-card rounded-2xl p-8 border border-teal-500/15 relative overflow-hidden">
            <!-- Glow inside card -->
            <div class="absolute -top-8 -right-8 w-48 h-48 bg-teal-500/10 rounded-full blur-2xl"></div>

            <div class="relative z-10 space-y-8">
              <!-- Stat 1 -->
              <div class="flex items-center gap-6">
                <div class="text-4xl font-black gradient-text-teal">~5s</div>
                <div>
                  <div class="text-white font-semibold">Average processing time</div>
                  <div class="text-slate-500 text-sm">from upload to download</div>
                </div>
              </div>

              <div class="h-px bg-gradient-to-r from-teal-500/20 to-transparent"></div>

              <!-- Stat 2 -->
              <div class="flex items-center gap-6">
                <div class="text-4xl font-black gradient-text">4+</div>
                <div>
                  <div class="text-white font-semibold">Photo presets</div>
                  <div class="text-slate-500 text-sm">growing library of use-cases</div>
                </div>
              </div>

              <div class="h-px bg-gradient-to-r from-teal-500/20 to-transparent"></div>

              <!-- Stat 3 -->
              <div class="flex items-center gap-6">
                <div class="text-4xl font-black" style="background: linear-gradient(135deg, #fb923c, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">HD</div>
                <div>
                  <div class="text-white font-semibold">Output quality</div>
                  <div class="text-slate-500 text-sm">print-ready high resolution</div>
                </div>
              </div>

              <div class="h-px bg-gradient-to-r from-teal-500/20 to-transparent"></div>

              <!-- CTA inside card -->
              <a
                href="/app"
                class="group flex items-center justify-between w-full px-5 py-3 rounded-xl font-semibold text-sm text-white transition-all duration-300 hover:scale-[1.02]"
                style="background: linear-gradient(135deg, rgba(20,184,166,0.2), rgba(129,140,248,0.2)); border: 1px solid rgba(20,184,166,0.3);"
              >
                <span>Generate my photo →</span>
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>
          </div>

          <!-- Floating badge -->
          <div
            class="absolute -top-4 -left-4 px-4 py-2 rounded-xl text-xs font-bold border glass-card border-teal-500/30 text-teal-300"
            style="animation: float 4s ease-in-out infinite;"
          >
            ✦ Free to try
          </div>

          <div
            class="absolute -bottom-4 -right-4 px-4 py-2 rounded-xl text-xs font-bold border glass-card border-violet-500/30 text-violet-300"
            style="animation: float 4s ease-in-out infinite; animation-delay: 2s;"
          >
            ✦ No account needed
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-10px); }
  }
</style>
