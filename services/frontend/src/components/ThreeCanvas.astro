---
// ThreeCanvas.astro — Abstract B&W Geometry WebGL Background
---

<canvas id="bg-canvas"></canvas>

<style>
  #bg-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    pointer-events: none;
    opacity: 0.7; /* Keep it subtle so it doesn't overpower text */
  }
</style>

<script>
  import * as THREE from 'three';

  function initThree() {
    const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;

    // 1. Scene Setup
    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x000000, 0.035);

    const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 8;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(window.innerWidth, window.innerHeight);

    // 2. Abstract Geometry
    const material = new THREE.MeshBasicMaterial({
      color: 0xffffff,
      wireframe: true,
      transparent: true,
      opacity: 0.12
    });
    
    // A large complex wireframe (Icosahedron)
    const meshOuter = new THREE.Mesh(new THREE.IcosahedronGeometry(4, 1), material);
    // An inner geometric core
    const meshInner = new THREE.Mesh(new THREE.IcosahedronGeometry(2, 0), material);
    
    const group = new THREE.Group();
    group.add(meshOuter);
    group.add(meshInner);
    
    // Push it slightly right on desktop
    if (window.innerWidth > 768) {
      group.position.x = 2;
    }
    scene.add(group);

    // 3. Floating Particles (Dust)
    const particlesGeom = new THREE.BufferGeometry();
    const particlesCount = 900;
    const posArray = new Float32Array(particlesCount * 3);
    for (let i = 0; i < particlesCount * 3; i++) {
      posArray[i] = (Math.random() - 0.5) * 35; // Spread over -17.5 to 17.5
    }
    particlesGeom.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
    const particlesMat = new THREE.PointsMaterial({
      size: 0.025,
      color: 0xffffff,
      transparent: true,
      opacity: 0.3
    });
    const particles = new THREE.Points(particlesGeom, particlesMat);
    scene.add(particles);

    // 4. Resize Handling
    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
      if (window.innerWidth > 768) group.position.x = 2;
      else group.position.x = 0;
    });

    // 5. Scroll Interaction Hook
    let scrollY = window.scrollY;
    let targetScroll = scrollY;
    window.addEventListener('scroll', () => {
      targetScroll = window.scrollY;
    });

    // 6. Render Loop
    const clock = new THREE.Clock();
    
    function animate() {
      const elapsedTime = clock.getElapsedTime();
      
      // Smooth lerp for scroll to feel buttery
      scrollY += (targetScroll - scrollY) * 0.05;
      
      // Rotate the group based on scroll + constant slow time
      group.rotation.x = scrollY * 0.0008 + elapsedTime * 0.05;
      group.rotation.y = scrollY * 0.0012 + elapsedTime * 0.08;
      
      // Counter-rotate the inner mesh for complexity
      meshInner.rotation.x = -elapsedTime * 0.15;
      meshInner.rotation.y = -elapsedTime * 0.1;

      // Parallax camera move based on scroll
      camera.position.y = -(scrollY * 0.0015);

      // Rotate particles slowly
      particles.rotation.y = scrollY * 0.0003 + elapsedTime * 0.02;

      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    }
    
    animate();
  }

  // Ensure it runs exactly once
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initThree);
  } else {
    initThree();
  }
</script>
