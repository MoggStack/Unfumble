---
// Navbar.astro — floating "dynamic island" pill
// Transparent glass at rest; darkens, lifts, and expands a CTA on scroll.
---

<header id="navbar">
  <nav id="nav-pill" aria-label="Main">

    <!-- Logo -->
    <a href="/" class="nav-logo">
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="nav-mark">
        <path d="M3 9V3h6" stroke="#fafafa" stroke-width="2.5"/>
        <path d="M23 3h6v6" stroke="#fafafa" stroke-width="2.5"/>
        <path d="M29 23v6h-6" stroke="#fafafa" stroke-width="2.5"/>
        <path d="M9 29H3v-6" stroke="#fafafa" stroke-width="2.5"/>
        <circle cx="16" cy="12.5" r="4.25" fill="#fafafa"/>
        <path d="M8.5 25.5c0-4.4 3.4-6.9 7.5-6.9s7.5 2.5 7.5 6.9z" fill="#fafafa"/>
      </svg>
      <span class="nav-name">UnFumble</span>
      <span class="nav-beta">Beta</span>
    </a>

    <!-- Links -->
    <div class="nav-links">
      <a href="#how-it-works" data-spy="how-it-works">How it works</a>
      <a href="#before-after" data-spy="before-after">See it work</a>
      <a href="#use-cases" data-spy="use-cases">Use cases</a>
      <a href="#why-us" data-spy="why-us">Why us</a>
    </div>

    <!-- CTA — expands out of the island once the hero CTA scrolls away -->
    <a href="/app" class="nav-cta">Unfumble my photos →</a>

  </nav>
</header>

<style>
  #navbar {
    position: fixed;
    top: 0.9rem;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    padding: 0 1rem;
    pointer-events: none;
  }

  #nav-pill {
    pointer-events: auto;
    display: flex;
    align-items: center;
    padding: 0.45rem 0.55rem 0.45rem 1.1rem;
    border-radius: 999px;
    background: rgba(10, 10, 10, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(18px) saturate(1.5);
    -webkit-backdrop-filter: blur(18px) saturate(1.5);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
    transition: background 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
  }
  #nav-pill.scrolled {
    background: rgba(8, 8, 8, 0.85);
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow: 0 14px 44px rgba(0, 0, 0, 0.6);
  }

  /* — Logo — */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    padding-right: 0.9rem;
  }
  .nav-mark { width: 22px; height: 22px; flex-shrink: 0; }
  .nav-name {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 900;
    color: #fafafa;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .nav-beta {
    font-family: 'Space Mono', monospace;
    font-size: 0.48rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #888;
    padding: 2px 6px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 999px;
  }

  /* — Links — */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.1rem;
    padding: 0 0.4rem;
    border-left: 1px solid rgba(255, 255, 255, 0.08);
  }
  .nav-links a {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    color: #8a8a8a;
    text-decoration: none;
    letter-spacing: 0.01em;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    transition: color 0.2s, background 0.2s;
    white-space: nowrap;
  }
  .nav-links a:hover { color: #fafafa; }
  .nav-links a.active {
    color: #fafafa;
    background: rgba(255, 255, 255, 0.08);
  }

  /* — CTA: permanently visible in the island — */
  .nav-cta {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
    color: #080808;
    background: #fafafa;
    border-radius: 999px;
    letter-spacing: 0.02em;
    white-space: nowrap;
    padding: 0.5rem 1.1rem;
    margin-left: 0.5rem;
    transition: background 0.2s, color 0.2s;
  }
  .nav-cta:hover {
    background: #080808;
    color: #fafafa;
    box-shadow: inset 0 0 0 1px #fafafa;
  }

  /* — Mobile: logo + CTA only — */
  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-logo { padding-right: 0.4rem; }
  }
</style>

<script>
  const pill = document.getElementById('nav-pill');

  function onScroll() {
    pill?.classList.toggle('scrolled', window.scrollY > 60);
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Scroll-spy: highlight the section currently in view
  const spyLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-links a[data-spy]');
  const sections = Array.from(spyLinks)
    .map((a) => document.getElementById(a.dataset.spy || ''))
    .filter((s): s is HTMLElement => s !== null);

  if (sections.length) {
    const spy = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          spyLinks.forEach((a) => a.classList.toggle('active', a.dataset.spy === e.target.id));
        });
      },
      { rootMargin: '-35% 0px -55% 0px' }
    );
    sections.forEach((s) => spy.observe(s));
  }
</script>
