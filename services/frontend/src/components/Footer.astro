---
// Footer.astro
---

<footer class="relative border-t border-white/5 py-16 px-6 overflow-hidden">

  <!-- Top glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-px bg-gradient-to-r from-transparent via-teal-500/40 to-transparent"></div>

  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

      <!-- Brand column -->
      <div class="md:col-span-1">
        <div class="flex items-center gap-2.5 mb-4">
          <!-- Logo mark -->
          <div class="w-9 h-9 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, #14b8a6, #818cf8);">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.776 48.776 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z" />
            </svg>
          </div>
          <span class="text-xl font-extrabold gradient-text-teal tracking-tight">UnFumble</span>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed mb-6 max-w-xs">
          Your photo, perfected for every occasion — AI handles the rest.
        </p>
        <!-- GitHub link -->
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener noreferrer"
          id="footer-github"
          class="group inline-flex items-center gap-2.5 px-4 py-2 rounded-lg border border-slate-700 text-slate-400 hover:border-teal-500/50 hover:text-teal-300 text-sm font-medium transition-all duration-300 hover:bg-teal-500/5"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
          View on GitHub
          <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-all -translate-x-1 group-hover:translate-x-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-5">Product</h4>
        <ul class="space-y-3">
          <li><a href="#how-it-works" class="text-slate-400 hover:text-teal-300 text-sm transition-colors duration-200">How it works</a></li>
          <li><a href="#use-cases" class="text-slate-400 hover:text-teal-300 text-sm transition-colors duration-200">Use cases</a></li>
          <li><a href="#why-unfumble" class="text-slate-400 hover:text-teal-300 text-sm transition-colors duration-200">Why UnFumble</a></li>
          <li><a href="/app" class="text-slate-400 hover:text-teal-300 text-sm transition-colors duration-200">Try the app</a></li>
        </ul>
      </div>

      <!-- About -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-5">About</h4>
        <p class="text-slate-400 text-sm leading-relaxed mb-4">
          Built by two developers learning AI — experimenting with ML pipelines, generative models, and building tools that actually solve real problems.
        </p>
        <div class="flex items-center gap-2 px-3 py-2 rounded-lg bg-white/3 border border-white/8 text-xs text-slate-500 w-fit">
          <span class="w-2 h-2 rounded-full bg-teal-400 animate-pulse"></span>
          Actively in development
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-slate-600 text-xs">
        © 2025 UnFumble. Built with ♥ and too much coffee.
      </p>
      <p class="text-slate-600 text-xs">
        Powered by AI · Astro · Tailwind CSS
      </p>
    </div>

  </div>
</footer>
