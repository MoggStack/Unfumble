---
// Footer.astro — B&W Editorial Footer
---

<footer style="background:#080808;padding:6rem 1.5rem 3rem;border-top:1px solid rgba(255,255,255,0.06);">
  <div style="max-width:72rem;margin:0 auto;">

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:4rem;margin-bottom:4rem;" class="footer-grid">

      <!-- Brand -->
      <div style="grid-column: span 1;">
        <a href="/" style="display:flex;align-items:center;gap:0.75rem;text-decoration:none;margin-bottom:1.5rem;">
          <div style="width:24px;height:24px;display:flex;align-items:center;justify-content:center;">
            <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;">
              <path d="M3 9V3h6" stroke="#fafafa" stroke-width="2.5"/>
              <path d="M23 3h6v6" stroke="#fafafa" stroke-width="2.5"/>
              <path d="M29 23v6h-6" stroke="#fafafa" stroke-width="2.5"/>
              <path d="M9 29H3v-6" stroke="#fafafa" stroke-width="2.5"/>
              <circle cx="16" cy="12.5" r="4.25" fill="#fafafa"/>
              <path d="M8.5 25.5c0-4.4 3.4-6.9 7.5-6.9s7.5 2.5 7.5 6.9z" fill="#fafafa"/>
            </svg>
          </div>
          <span style="font-family:'Playfair Display',Georgia,serif;font-size:1.2rem;font-weight:900;color:#fafafa;letter-spacing:-0.02em;">UnFumble.</span>
        </a>
        <p style="font-family:'DM Sans',system-ui,sans-serif;color:#5a5a5a;font-size:0.875rem;line-height:1.7;max-width:220px;margin-bottom:1.5rem;">
          Your worst shots, turned into your best profile photo.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 style="font-family:'Space Mono',monospace;font-size:0.65rem;font-weight:400;text-transform:uppercase;letter-spacing:0.15em;color:#888;margin-bottom:1.5rem;">Product</h4>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:1rem;padding:0;margin:0;">
          {[
            ['#how-it-works', 'How it works'],
            ['#use-cases',    'Use cases'],
            ['#why-us',       'Why UnFumble'],
            ['/app/',          'Try the app'],
          ].map(([href, label]) => (
            <li>
              <a
                href={href}
                style="font-family:'DM Sans',system-ui,sans-serif;color:#5a5a5a;font-size:0.9rem;text-decoration:none;transition:color 0.2s;"
                onmouseover="this.style.color='#fafafa'"
                onmouseout="this.style.color='#5a5a5a'"
              >{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- About -->
      <div>
        <h4 style="font-family:'Space Mono',monospace;font-size:0.65rem;font-weight:400;text-transform:uppercase;letter-spacing:0.15em;color:#888;margin-bottom:1.5rem;">Status</h4>
        <div style="display:inline-flex;align-items:center;gap:0.6rem;padding:0.4rem 0.8rem;border:1px solid rgba(255,255,255,0.15);color:#fafafa;font-family:'Space Mono',monospace;font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;">
          <span style="width:6px;height:6px;background:#fafafa;display:inline-block;animation:pulse 2s infinite;"></span>
          Beta Access
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div style="padding-top:2rem;border-top:1px solid rgba(255,255,255,0.06);display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:1rem;">
      <p style="font-family:'DM Sans',system-ui,sans-serif;color:#5a5a5a;font-size:0.75rem;">© 2026 UnFumble.</p>
      <p style="font-family:'Space Mono',monospace;color:#5a5a5a;font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;">Editorial Edition</p>
    </div>

  </div>
</footer>

<style>
  @media (min-width: 768px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr !important; }
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }
</style>
