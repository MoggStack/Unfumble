---
// UseCaseCards.astro — 4 use-case cards with hover 3D tilt effect

const useCases = [
  {
    id: 'passport',
    label: 'Passport',
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253" /></svg>`,
    description: 'Plain white background, perfectly centered crop, meets international compliance standards.',
    tags: ['White BG', 'Centered', 'Compliant'],
    accent: '#14b8a6',
    glow: 'rgba(20,184,166,0.25)',
    gradient: 'from-teal-500/10 to-cyan-500/5',
    border: 'border-teal-500/20',
    hoverBorder: 'hover:border-teal-400/50',
    tagColor: 'text-teal-300 bg-teal-500/10 border-teal-500/20',
  },
  {
    id: 'linkedin',
    label: 'LinkedIn',
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" /></svg>`,
    description: 'Professional headshot with softly blurred background — the first impression that lands offers.',
    tags: ['Headshot', 'Bokeh BG', 'Professional'],
    accent: '#818cf8',
    glow: 'rgba(129,140,248,0.25)',
    gradient: 'from-violet-500/10 to-indigo-500/5',
    border: 'border-violet-500/20',
    hoverBorder: 'hover:border-violet-400/50',
    tagColor: 'text-violet-300 bg-violet-500/10 border-violet-500/20',
  },
  {
    id: 'instagram',
    label: 'Instagram',
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.776 48.776 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" /><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z" /></svg>`,
    description: 'Vibrant, well-lit, flattering crop — optimized for the feed, stories, and profile picture.',
    tags: ['Vibrant', 'Well-lit', 'Feed-ready'],
    accent: '#e879f9',
    glow: 'rgba(232,121,249,0.25)',
    gradient: 'from-fuchsia-500/10 to-pink-500/5',
    border: 'border-fuchsia-500/20',
    hoverBorder: 'hover:border-fuchsia-400/50',
    tagColor: 'text-fuchsia-300 bg-fuchsia-500/10 border-fuchsia-500/20',
  },
  {
    id: 'job-application',
    label: 'Job Application',
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>`,
    description: 'Clean, neutral, formal — exactly what hiring managers expect. Confident but approachable.',
    tags: ['Neutral', 'Formal', 'Confident'],
    accent: '#fb923c',
    glow: 'rgba(251,146,60,0.25)',
    gradient: 'from-orange-500/10 to-amber-500/5',
    border: 'border-orange-500/20',
    hoverBorder: 'hover:border-orange-400/50',
    tagColor: 'text-orange-300 bg-orange-500/10 border-orange-500/20',
  },
];
---

<section id="use-cases" class="relative py-32 px-6 overflow-hidden">

  <!-- Background gradient blobs -->
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-violet-500/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-teal-500/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-6xl mx-auto">

    <!-- Section header -->
    <div class="text-center mb-20 reveal">
      <span class="inline-block px-4 py-1 rounded-full text-sm font-semibold text-violet-400 bg-violet-400/10 border border-violet-400/20 mb-4 tracking-wider uppercase">
        Use Cases
      </span>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-white mb-4">
        One tool,
        <span class="gradient-text"> every context</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-xl mx-auto">
        Whether you need to impress an immigration officer or your future employer, we've got a preset for it.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {useCases.map((uc, i) => (
        <div
          class={`reveal reveal-delay-${i + 1} tilt-card group relative rounded-2xl p-6 border glass-card ${uc.border} ${uc.hoverBorder} transition-all duration-500 hover:scale-[1.03] cursor-pointer overflow-hidden`}
          data-id={uc.id}
          style={`--card-glow: ${uc.glow}; --card-accent: ${uc.accent};`}
        >
          <!-- Card background gradient -->
          <div class={`absolute inset-0 bg-gradient-to-br ${uc.gradient} opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl`}></div>

          <!-- Glow effect on hover -->
          <div
            class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style={`box-shadow: inset 0 0 30px ${uc.glow};`}
          ></div>

          <!-- Content -->
          <div class="relative z-10">
            <!-- Icon -->
            <div
              class="w-12 h-12 rounded-xl flex items-center justify-center mb-5 transition-transform duration-300 group-hover:scale-110"
              style={`color: ${uc.accent}; background: ${uc.glow.replace('0.25', '0.15')};`}
            >
              <div class="w-6 h-6" set:html={uc.icon} />
            </div>

            <!-- Label -->
            <h3 class="text-lg font-bold text-white mb-2">{uc.label}</h3>

            <!-- Description -->
            <p class="text-slate-400 text-sm leading-relaxed mb-4">{uc.description}</p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5">
              {uc.tags.map((tag) => (
                <span class={`px-2 py-0.5 rounded text-xs font-medium border ${uc.tagColor}`}>{tag}</span>
              ))}
            </div>

            <!-- Arrow hint -->
            <div class="mt-4 flex items-center gap-1 text-xs font-semibold opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-1 group-hover:translate-y-0"
                 style={`color: ${uc.accent};`}>
              Try this preset
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  // 3D tilt effect on cards
  document.querySelectorAll<HTMLElement>('.tilt-card').forEach((card) => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const cx = rect.left + rect.width  / 2;
      const cy = rect.top  + rect.height / 2;
      const dx = (e.clientX - cx) / (rect.width  / 2);
      const dy = (e.clientY - cy) / (rect.height / 2);
      card.style.transform = `perspective(800px) rotateX(${-dy * 6}deg) rotateY(${dx * 6}deg) scale(1.03)`;
    });

    card.addEventListener('mouseleave', () => {
      card.style.transform = '';
    });
  });
</script>
