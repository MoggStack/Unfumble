---
// UseCaseCards.astro — B&W Editorial Use Cases
---

<section id="use-cases" style="background:#080808;padding:8rem 1.5rem;position:relative;border-top:1px solid rgba(255,255,255,0.06);">
  <div style="max-width:72rem;margin:0 auto;">

    <!-- Header -->
    <div class="reveal" style="display:flex;align-items:flex-end;justify-content:space-between;gap:2rem;margin-bottom:5rem;flex-wrap:wrap;">
      <div class="reveal">
        <p style="font-family:'Space Mono',monospace;font-size:0.65rem;letter-spacing:0.18em;text-transform:uppercase;color:#5a5a5a;margin-bottom:1.25rem;">
          Aesthetic Grading
        </p>
        <h2 class="reveal-up" style="font-family:'DM Sans',system-ui,sans-serif;font-size:clamp(2.2rem,5vw,4rem);font-weight:400;line-height:1.0;letter-spacing:-0.05em;color:#fafafa;max-width:350px;">
          One profile. <br/><em style="font-family:'Playfair Display',Georgia,serif;font-weight:900;font-style:italic;letter-spacing:-0.02em;">Any style.</em>
        </h2>
      </div>
      <p style="font-family:'DM Sans',system-ui,sans-serif;font-size:1rem;font-weight:300;color:#5a5a5a;max-width:300px;line-height:1.7;margin-bottom:0.25rem;">
        Whether impressing immigration or your future employer — we've got a preset for it.
      </p>
    </div>

    <!-- Cards Grid -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:0;border:1px solid rgba(255,255,255,0.06);">

      <!-- Card 1: Studio Lighting -->
      <div class="reveal d1 ccard-hover" style="padding:2.5rem;border-right:1px solid rgba(255,255,255,0.06);border-bottom:1px solid rgba(255,255,255,0.06);position:relative;transition:background 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background='transparent'">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:2rem;">
          <span style="font-family:'Playfair Display',Georgia,serif;font-size:1.5rem;font-weight:900;color:#fafafa;">Studio</span>
          <span style="font-family:'Space Mono',monospace;font-size:0.55rem;letter-spacing:0.1em;padding:2px 6px;border:1px solid rgba(255,255,255,0.15);color:#888;">SHARP</span>
        </div>
        <p style="font-family:'DM Sans',system-ui,sans-serif;font-size:0.875rem;font-weight:300;color:#5a5a5a;line-height:1.75;margin-bottom:2rem;">
          Crisp, perfectly balanced lighting simulating a high-end photography setup. Ideal for professional contexts.
        </p>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.5rem;">
          {['Clean', 'Balanced'].map(t => (
            <span style="font-family:'Space Mono',monospace;font-size:0.55rem;letter-spacing:0.08em;padding:3px 7px;border:1px solid rgba(255,255,255,0.08);color:#5a5a5a;text-transform:uppercase;">{t}</span>
          ))}
        </div>
        <a href="/app" style="display:inline-flex;align-items:center;gap:0.5rem;font-family:'DM Sans',system-ui,sans-serif;font-size:0.8rem;font-weight:600;color:#fafafa;text-decoration:none;transition:gap 0.3s;" class="cta-link">
          Select style <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>

      <!-- Card 2: B&W Editorial -->
      <div class="reveal d2 ccard-hover" style="padding:2.5rem;border-bottom:1px solid rgba(255,255,255,0.06);position:relative;transition:background 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background='transparent'">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:2rem;">
          <span style="font-family:'Playfair Display',Georgia,serif;font-size:1.5rem;font-weight:900;color:#fafafa;">Editorial</span>
          <span style="font-family:'Space Mono',monospace;font-size:0.55rem;letter-spacing:0.1em;padding:2px 6px;border:1px solid rgba(255,255,255,0.15);color:#888;">CLEAN</span>
        </div>
        <p style="font-family:'DM Sans',system-ui,sans-serif;font-size:0.875rem;font-weight:300;color:#5a5a5a;line-height:1.75;margin-bottom:2rem;">
          Stark, high-contrast monochrome conversion for a timeless magazine aesthetic.
        </p>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.5rem;">
          {['Monochrome', 'Contrast'].map(t => (
            <span style="font-family:'Space Mono',monospace;font-size:0.55rem;letter-spacing:0.08em;padding:3px 7px;border:1px solid rgba(255,255,255,0.08);color:#5a5a5a;text-transform:uppercase;">{t}</span>
          ))}
        </div>
        <a href="/app" style="display:inline-flex;align-items:center;gap:0.5rem;font-family:'DM Sans',system-ui,sans-serif;font-size:0.8rem;font-weight:600;color:#fafafa;text-decoration:none;transition:gap 0.3s;" class="cta-link">
          Select style <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>

      <!-- Card 3: Cinematic -->
      <div class="reveal d3 ccard-hover" style="padding:2.5rem;border-right:1px solid rgba(255,255,255,0.06);position:relative;transition:background 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background='transparent'">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:2rem;">
          <span style="font-family:'Playfair Display',Georgia,serif;font-size:1.5rem;font-weight:900;color:#fafafa;">Cinematic</span>
          <span style="font-family:'Space Mono',monospace;font-size:0.55rem;letter-spacing:0.1em;padding:2px 6px;border:1px solid rgba(255,255,255,0.15);color:#888;">VIBRANT</span>
        </div>
        <p style="font-family:'DM Sans',system-ui,sans-serif;font-size:0.875rem;font-weight:300;color:#5a5a5a;line-height:1.75;margin-bottom:2rem;">
          Rich color grading and depth-of-field adjustments simulating a 35mm film lens.
        </p>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.5rem;">
          {['Color Graded', 'Bokeh'].map(t => (
            <span style="font-family:'Space Mono',monospace;font-size:0.55rem;letter-spacing:0.08em;padding:3px 7px;border:1px solid rgba(255,255,255,0.08);color:#5a5a5a;text-transform:uppercase;">{t}</span>
          ))}
        </div>
        <a href="/app" style="display:inline-flex;align-items:center;gap:0.5rem;font-family:'DM Sans',system-ui,sans-serif;font-size:0.8rem;font-weight:600;color:#fafafa;text-decoration:none;transition:gap 0.3s;" class="cta-link">
          Select style <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>

      <!-- Card 4: Vintage -->
      <div class="reveal d4 ccard-hover" style="padding:2.5rem;position:relative;transition:background 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background='transparent'">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:2rem;">
          <span style="font-family:'Playfair Display',Georgia,serif;font-size:1.5rem;font-weight:900;color:#fafafa;">Vintage</span>
          <span style="font-family:'Space Mono',monospace;font-size:0.55rem;letter-spacing:0.1em;padding:2px 6px;border:1px solid rgba(255,255,255,0.15);color:#888;">CLASSIC</span>
        </div>
        <p style="font-family:'DM Sans',system-ui,sans-serif;font-size:0.875rem;font-weight:300;color:#5a5a5a;line-height:1.75;margin-bottom:2rem;">
          Subtle film grain, warm halation, and faded shadows for an iconic 90s snapshot feel.
        </p>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.5rem;">
          {['Grain', 'Halation'].map(t => (
            <span style="font-family:'Space Mono',monospace;font-size:0.55rem;letter-spacing:0.08em;padding:3px 7px;border:1px solid rgba(255,255,255,0.08);color:#5a5a5a;text-transform:uppercase;">{t}</span>
          ))}
        </div>
        <a href="/app" style="display:inline-flex;align-items:center;gap:0.5rem;font-family:'DM Sans',system-ui,sans-serif;font-size:0.8rem;font-weight:600;color:#fafafa;text-decoration:none;transition:gap 0.3s;" class="cta-link">
          Select style <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>

    </div>

  </div>
</section>

<style>
  /* Equal-height cards: description stretches so chips + CTA bottom-align across the row */
  .ccard-hover { display: flex; flex-direction: column; }
  .ccard-hover > p { flex: 1; }
  .ccard-hover:hover .cta-link { gap: 0.75rem !important; }
  
  @media (max-width: 768px) {
    .ccard-hover { border-right: none !important; border-bottom: 1px solid rgba(255,255,255,0.06) !important; }
    .ccard-hover:last-child { border-bottom: none !important; }
  }
</style>
