---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'UnFumble — Turn Your Worst Photos into One Perfect Profile Picture',
  description = 'Side angles, blurry selfies, bad lighting — upload them all. UnFumble\'s AI builds one clean, professional profile photo from your worst shots, in seconds.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Premium font trio: editorial serif + clean sans + monospace -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700;1,900&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300;1,9..40,400&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline>
      // 1. Bulletproof Vanilla JS Text Splitter
      document.querySelectorAll('.split-text').forEach((el) => {
        const text = el.textContent.trim();
        const words = text.split(' ');
        el.innerHTML = '';
        words.forEach((word, index) => {
          const wrapper = document.createElement('span');
          wrapper.style.display = 'inline-block';
          wrapper.style.overflow = 'hidden';
          wrapper.style.verticalAlign = 'top';
          if (index < words.length - 1) wrapper.style.marginRight = '0.25em';
          
          const inner = document.createElement('span');
          inner.className = 'split-inner';
          inner.style.display = 'inline-block';
          inner.style.transform = 'translateY(110%) rotate(4deg)';
          inner.style.transformOrigin = 'top left';
          inner.style.opacity = '0';
          inner.style.transition = 'transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.8s ease';
          inner.style.transitionDelay = `${index * 0.04}s`;
          inner.textContent = word;
          
          wrapper.appendChild(inner);
          el.appendChild(wrapper);
        });
      });

      // 2. Scroll Reveal Observer
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              // Standard reveals
              e.target.classList.add('in');
              
              // Text split reveals
              if (e.target.classList.contains('split-text')) {
                const inners = e.target.querySelectorAll('.split-inner');
                inners.forEach(inner => {
                  inner.style.transform = 'translateY(0) rotate(0)';
                  inner.style.opacity = '1';
                });
              }
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: "0px 0px -5% 0px" }
      );
      document.querySelectorAll('.reveal, .reveal-up, .split-text').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
